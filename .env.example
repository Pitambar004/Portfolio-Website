# Copy to `.env` for local dev (never commit `.env` ‚Äî it is gitignored):
#   cp .env.example .env
#
# Vite replaces import.meta.env.VITE_* at BUILD time, so values end up in the JS bundle.
# For production on Vercel: Project ‚Üí Settings ‚Üí Environment Variables ‚Üí add each variable
# for "Production", then trigger a new deployment (Redeploy) so the build picks them up.

# Required for /admin login (pick a strong password; treat as casual lock, not bank-grade).
VITE_ADMIN_PASSWORD=

# Canonical site URL (no trailing slash) ‚Äî used in index.html meta + robots/sitemap build output.
VITE_SITE_URL=https://example.com

# Optional full URL to Open Graph / social preview image (defaults to VITE_SITE_URL + /og-image.png).
# VITE_OG_IMAGE_URL=https://example.com/og-image.png
