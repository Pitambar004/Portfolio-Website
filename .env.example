# Canonical site URL (no trailing slash). Used for meta tags, canonical, sitemap, and robots.
# Replace with your live domain before production build, e.g. https://pitambarpandey.com
VITE_SITE_URL=https://example.com

# Optional: full URL to Open Graph / Twitter preview image (1200×630 PNG or JPG recommended).
# If unset, defaults to {VITE_SITE_URL}/og-image.png — add that file under public/ or set this to an absolute URL.
# VITE_OG_IMAGE_URL=https://example.com/og-image.png
